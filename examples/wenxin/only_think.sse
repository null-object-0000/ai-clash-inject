data:{"code":0,"msg":"success","data":{"content":"。","text":null,"aiEditContent":null,"greetType":"","citationInfo":null,"searchCitations":null,"citations":null,"pluginCitations":null,"stop":0,"tips":"","wordGengStatus":false,"pluginInfo":null,"isIncr":true,"isBan":false,"flag":0,"logid":"118000284121214248","isWithdraw":false,"showWarning":0,"qiangguoIsWithDraw":null,"sessionBan":null,"sessionDel":false,"needClearHistory":null,"usageVo":null,"isSafe":1,"sessionId":5166538671,"firstChat":true,"chatType":"ASSISTANT","markUpChatType":null,"ques":null,"newAppSessionId":null,"role":"assistant","isAssistant":true,"annotations":[],"stream":null,"tipAction":null,"waitTime":null,"waitTimeEB45":null,"waitTimeEBX1":null,"waitTimeThis":null,"waitModelThis":null,"assistantTopicId":null,"isVideoRecommendLoading":false,"statisticRound":null,"tipToolName":null,"recommendQuesList":null,"aiEditButton":false,"aiEditRes":null,"artifact":null,"notAiEditPlugin":false,"errorMsg":null,"simpleClose":false,"agent":false,"content_type":"text","sent_id":593,"is_end":0,"is_truncated":0,"error_code":0,"chat_id":"24230694168","tokens_all":"","tokens_all_json":null,"function_call":null,"create_time":null,"finish_reason":null,"message_id":0,"message_type":"default","token_confidence":null,"tool_calls":null},"logId":null}
